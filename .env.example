# EthSyncAuditor — environment variables
# Copy this file to .env and fill in the values you need.
# Existing shell environment variables take precedence over values here.

# ── LLM Provider API Keys ──────────────────────────────────────────────
# At least one key is required (unless running in --mock mode).
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ── API Proxy / Custom Endpoints (optional) ────────────────────────────
# Leave empty to use each provider's default endpoint.
ANTHROPIC_BASE_URL=
GOOGLE_API_BASE=
